# Backend Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# Local development: postgresql://user:password@localhost:5432/maigun
# Render: postgres://user:password@host/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/maigun_dev

# Queue (BullMQ / Redis)
REDIS_URL=

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_WEBHOOK_SIGNING_KEY=your-mailgun-webhook-signing-key
MAILGUN_DOMAIN=your-mailgun-domain

# Electron Origin (allow CORS from this origin)
ELECTRON_ORIGIN=http://localhost:5173

# API Authentication
API_TOKEN=dev-token-12345

# Webhook URL (for Mailgun to callback)
WEBHOOK_URL=http://localhost:3000/api/webhooks

# Optional public base URL for hosted email assets (social icons)
# Example: https://maigun-backend-xxxxx.onrender.com
EMAIL_ASSET_BASE_URL=

# Logging
DEBUG=false
