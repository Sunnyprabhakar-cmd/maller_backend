{
  "name": "maigun-from-scratch",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test:ui": "node --import ./backend/node_modules/tsx/dist/loader.mjs --import ./src/renderer/src/test/register-dom.ts --test src/renderer/src/**/*.ui.test.tsx",
    "test:renderer": "node --import ./backend/node_modules/tsx/dist/loader.mjs --test src/renderer/src/**/*.test.ts",
    "test:backend": "cd backend && npm test",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "npm run dev & npm run dev:backend",
    "setup": "npm install && cd backend && npm install && npm run db:generate",
    "test:email": "echo 'Create a campaign in the app and send a test email to verify setup'"
  },
  "dependencies": {
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.10",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-vite": "^3.1.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vitest": "^4.1.2"
  }
}
