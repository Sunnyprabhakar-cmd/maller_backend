    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
